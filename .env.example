# Copy to .env for local dev, and set these in your Vercel project settings
# for production. NONE are required for a basic test deploy — the site runs
# on static content and degrades gracefully when they're absent.

# --- Database (optional) ---
# Leave unset for a static-only test deploy. To enable DB-backed case studies
# and persisted newsletter signups, provision a free Postgres (e.g. Neon or
# Vercel Postgres) and paste its connection string here, then run:
#   npx prisma db push
DATABASE_URL=

# --- Email / newsletter (optional) ---
# Without these, the newsletter endpoint still returns success but sends no mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=

# --- Site config (optional) ---
NEXT_PUBLIC_WEB=
NEXT_PUBLIC_SITE_URL=

# --- Calendly scheduling (optional) ---
# Your Calendly event link, e.g. https://calendly.com/your-name/30min
# The "Book a Call" buttons open this in a popup. Falls back to a demo link.
NEXT_PUBLIC_CALENDLY_URL=

# --- Admin (optional) ---
# Protects the POST /api/case-studies endpoint. Set to a strong random value
# if you use it.
ADMIN_API_KEY=

# --- Google reviews (optional) ---
# Feeds the testimonials section from your Google Business Profile. Without
# these it shows the hand-written testimonials from site-data.ts.
# 1. In Google Cloud Console, create an API key with "Places API (New)"
#    enabled (billing must be on; Place Details has a free monthly tier).
# 2. Find your business's Place ID:
#    https://developers.google.com/maps/documentation/places/web-service/place-id
# Note: Google's API returns the 5 "most relevant" reviews, refreshed hourly.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=
